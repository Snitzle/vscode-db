{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "shell": {
          "executable": "/usr/bin/bash",
          "args": [
            "-ic"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": [
        "$esbuild-watch",
        "$tsc-watch"
      ],
      "presentation": {
        "reveal": "never",
        "group": "watch"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "npm: build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "shell": {
          "executable": "/usr/bin/bash",
          "args": [
            "-ic"
          ]
        }
      },
      "problemMatcher": [
        "$tsc"
      ],
      "detail": "One-shot fallback if the background watch task misbehaves (e.g. the esbuild problem-matchers extension is not installed)."
    }
  ]
}
