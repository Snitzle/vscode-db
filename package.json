{
  "name": "openvsdb",
  "displayName": "OpenVSDB",
  "description": "Browse and edit MySQL and SQLite databases from a VS Code sidebar tree and editor tabs.",
  "version": "0.1.2",
  "publisher": "local",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Snitzle/OpenVSDB.git"
  },
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbExplorer",
          "title": "OpenVSDB",
          "icon": "media/database.svg"
        }
      ]
    },
    "views": {
      "dbExplorer": [
        {
          "type": "webview",
          "id": "dbExplorer.home",
          "name": "Database Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "dbExplorer.open",
        "title": "OpenVSDB: Focus",
        "icon": "$(window)"
      },
      {
        "command": "dbExplorer.addConnection",
        "title": "OpenVSDB: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "dbExplorer.refresh",
        "title": "OpenVSDB: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "dbExplorer.runSqlDocument",
        "title": "OpenVSDB: Run SQL File on Connection",
        "icon": "$(play)"
      },
      {
        "command": "dbExplorer.bindSqlDocument",
        "title": "OpenVSDB: Select Connection for SQL File",
        "icon": "$(database)"
      },
      {
        "command": "dbExplorer.clearQueryHistory",
        "title": "OpenVSDB: Clear Query History"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbExplorer.addConnection",
          "when": "view == dbExplorer.home",
          "group": "navigation@1"
        },
        {
          "command": "dbExplorer.refresh",
          "when": "view == dbExplorer.home",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "dbExplorer.runSqlDocument",
          "when": "resourceLangId == sql",
          "group": "navigation@1"
        }
      ]
    },
    "languageModelTools": [
      {
        "name": "openvsdb_listSchemas",
        "displayName": "List Database Schemas",
        "toolReferenceName": "dbSchemas",
        "canBeReferencedInPrompt": true,
        "icon": "$(database)",
        "modelDescription": "List the schemas, tables, and views of a database connection configured in OpenVSDB. Call with no arguments first to discover connections when unsure.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "connection": {
              "type": "string",
              "description": "Connection name or id. Optional when only one connection exists."
            }
          }
        }
      },
      {
        "name": "openvsdb_describeTable",
        "displayName": "Describe Database Table",
        "toolReferenceName": "dbTable",
        "canBeReferencedInPrompt": true,
        "icon": "$(table)",
        "modelDescription": "Describe a table on an OpenVSDB connection: columns with types, nullability, keys, auto-increment, plus the CREATE statement.",
        "inputSchema": {
          "type": "object",
          "required": [
            "table"
          ],
          "properties": {
            "connection": {
              "type": "string",
              "description": "Connection name or id. Optional when only one connection exists."
            },
            "schema": {
              "type": "string",
              "description": "Schema/database name. Defaults to the connection's default schema."
            },
            "table": {
              "type": "string",
              "description": "Table name to describe."
            }
          }
        }
      },
      {
        "name": "openvsdb_query",
        "displayName": "Run Read-Only SQL Query",
        "toolReferenceName": "dbQuery",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "modelDescription": "Run a single read-only SQL statement (SELECT / WITH…SELECT / EXPLAIN / SHOW / DESCRIBE) on an OpenVSDB connection and get up to 100 rows back as a markdown table. Data-modifying statements are rejected.",
        "inputSchema": {
          "type": "object",
          "required": [
            "sql"
          ],
          "properties": {
            "connection": {
              "type": "string",
              "description": "Connection name or id. Optional when only one connection exists."
            },
            "sql": {
              "type": "string",
              "description": "One read-only SQL statement."
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:esbuild watch:types",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:types": "tsc --noEmit --watch",
    "dev": "node esbuild.js --serve",
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "test": "mocha --require tsx/cjs \"test/**/*.test.ts\"",
    "test:watch": "mocha --require tsx/cjs --watch --watch-files src,test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "mysql2": "^3.14.0",
    "ssh2": "^1.17.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.99.1",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.21.5",
    "mocha": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "tabulator-tables": "^6.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
