{
  "name": "openvsdb",
  "displayName": "OpenVSDB",
  "description": "Browse and edit MySQL and SQLite databases from a VS Code sidebar tree and editor tabs.",
  "version": "0.0.1",
  "publisher": "snitzle",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Snitzle/OpenVSDB.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbExplorer",
          "title": "OpenVSDB",
          "icon": "media/database.svg"
        }
      ]
    },
    "views": {
      "dbExplorer": [
        {
          "type": "webview",
          "id": "dbExplorer.home",
          "name": "Database Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "dbExplorer.open",
        "title": "OpenVSDB: Focus",
        "icon": "$(window)"
      },
      {
        "command": "dbExplorer.addConnection",
        "title": "OpenVSDB: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "dbExplorer.refresh",
        "title": "OpenVSDB: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbExplorer.addConnection",
          "when": "view == dbExplorer.home",
          "group": "navigation@1"
        },
        {
          "command": "dbExplorer.refresh",
          "when": "view == dbExplorer.home",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:esbuild watch:types",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:types": "tsc --noEmit --watch",
    "dev": "node esbuild.js --serve",
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "test": "mocha --require tsx/cjs \"test/**/*.test.ts\"",
    "test:watch": "mocha --require tsx/cjs --watch --watch-files src,test \"test/**/*.test.ts\"",
    "package": "vsce package --target ${VSCE_TARGET:-$(node -p \"process.platform + '-' + process.arch\")}",
    "publish": "vsce publish --target ${VSCE_TARGET:-$(node -p \"process.platform + '-' + process.arch\")}"
  },
  "dependencies": {
    "mysql2": "^3.14.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.21.5",
    "mocha": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "tabulator-tables": "^6.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2",
    "@vscode/vsce": "^3.2.1"
  }
}
