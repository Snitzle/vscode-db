# Ship: dist/ (bundled extension + webview assets), media/main.css +
# media/database.svg (loaded at runtime), and production node_modules
# (sqlite3/mysql2/uuid stay external to the bundle).
.vscode/**
.vscode-test/**
.claude/**
.github/**
src/**
out/**
test/**
dev/**
media/main.js
media/tablePanel.js
media/vscodeApi.js
media/tabulator-vscode.css
esbuild.js
tsconfig.json
ROADMAP.md
WSL-SUPPORT-PLAN.md
.gitignore
**/*.map
# sqlite3 source/build inputs: only build/Release/node_sqlite3.node is needed at
# runtime, not the ~3 MB amalgamation sources or gyp build tree.
node_modules/sqlite3/deps/**
node_modules/sqlite3/src/**
node_modules/sqlite3/build/**
!node_modules/sqlite3/build/Release/node_sqlite3.node
